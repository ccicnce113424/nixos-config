Diff: https://github.com/kmscon/kmscon/compare/v9.3.4...v9.3.5

Changelog: https://github.com/kmscon/kmscon/releases/tag/v9.3.5
---
 pkgs/by-name/km/kmscon/package.nix | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/pkgs/by-name/km/kmscon/package.nix b/pkgs/by-name/km/kmscon/package.nix
index 5298f0b2391d6..bcecb5c8b5eb8 100644
--- a/pkgs/by-name/km/kmscon/package.nix
+++ b/pkgs/by-name/km/kmscon/package.nix
@@ -29,13 +29,13 @@
 }:
 stdenv.mkDerivation (finalAttrs: {
   pname = "kmscon";
-  version = "9.3.4";
+  version = "9.3.5";
 
   src = fetchFromGitHub {
     owner = "kmscon";
     repo = "kmscon";
     tag = "v${finalAttrs.version}";
-    hash = "sha256-S6a/m2gfYOsacq4uq3d05WZPH1C8RQowmZM7f6On4ic=";
+    hash = "sha256-QBN1rSDmwVg7cgljhe6kVIg/xLoolmOPqS8JXZuQiXs=";
   };
 
   strictDeps = true;

From cc4f2651cc282301014365b60a822f28095bbfd0 Mon Sep 17 00:00:00 2001
From: ccicnce113424 <ccicnce113424@gmail.com>
Date: Sat, 25 Apr 2026 14:17:23 +0800
Subject: [PATCH 2/2] nixos/kmscon: spawn kmscon on tty1 only if the display
 manager is disabled

---
 nixos/modules/services/ttys/kmscon.nix | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/nixos/modules/services/ttys/kmscon.nix b/nixos/modules/services/ttys/kmscon.nix
index cc69137a63453..e7d6070847fe9 100644
--- a/nixos/modules/services/ttys/kmscon.nix
+++ b/nixos/modules/services/ttys/kmscon.nix
@@ -156,7 +156,9 @@ in
 
     # tty1 is special: logind does not spawn autovt@tty1, it expects a static
     # pull-in via getty.target. With getty@ suppressed, we must replace it.
-    systemd.services."kmsconvt@tty1".wantedBy = [ "getty.target" ];
+    systemd.services."kmsconvt@tty1".wantedBy = lib.optionals (!config.services.displayManager.enable) [
+      "getty.target"
+    ];
 
     systemd.suppressedSystemUnits = [ "getty@.service" ];
 
