From 832a681c96bf753a44a9964d966aa4e199a17779 Mon Sep 17 00:00:00 2001
From: ccicnce113424 <ccicnce113424@gmail.com>
Date: Sat, 11 Apr 2026 09:59:00 +0800
Subject: [PATCH 1/4] nixosTests.kmscon: wait for default target before waiting
 for the text

---
 nixos/tests/kmscon.nix | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/nixos/tests/kmscon.nix b/nixos/tests/kmscon.nix
index 1c67a16af2bab..f0fb27d9b0d57 100644
--- a/nixos/tests/kmscon.nix
+++ b/nixos/tests/kmscon.nix
@@ -31,7 +31,7 @@
   enableOCR = true;
 
   testScript = ''
-    machine.start()
+    machine.wait_for_unit("default.target")
 
     with subtest("ensure we can open a tty"):
       machine.wait_for_text("alice@machine")

