// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "formatter": {
    "external": {
      "command": "nix",
      "arguments": ["fmt", "--", "{buffer_path}", "--stdin"]
    }
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    }
  },
  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.ccic-desktop.pkgs"
        },
        "options": {
          "flake-parts": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).debug.options"
          },
          "flake-parts2": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).currentSystem.options"
          },
          "nixos": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.ccic-desktop.options"
          },
          "home-manager": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.ccic-desktop.options.home-manager.users.type.getSubOptions []"
          }
        }
      }
    }
  }
}
